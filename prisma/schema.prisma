// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String?
  rol       Role     @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  driver    Driver?
}

enum Role {
  USER
  ADMIN
  BODEGUERO
  CARGADOR
  CHOFER
}

// Tablas y CRUD para empresas de transporte, vehículos, rutas, etc. se pueden agregar aquí según sea necesario.

//Entidad de empresas de transporte
model TransportCompany {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  drivers   Driver[]
  vehicles  Vehicle[]
  areas     InterestArea[]
}

//Entidad de conductores para las empresas de transporte
model Driver {
  id          String   @id @default(uuid())
  companyId   String
  company     TransportCompany @relation(fields: [companyId], references: [id])

  userId      String?  @unique
  user        User?    @relation(fields: [userId], references: [id])

  fullName    String
  documentId  String?
  phone       String?
  licenseType String?
  licenseExpiresAt DateTime?

  status      DriverStatus @default(ACTIVE)
  assignments DriverVehicleAssignment[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([fullName])
}
//Entidad de vehículos para las empresas de transporte
model Vehicle {
  id         String   @id @default(uuid())
  companyId  String
  company    TransportCompany @relation(fields: [companyId], references: [id])

  plate      String   @unique
  type       String?
  status     VehicleStatus @default(ACTIVE)

  gpsExternalId String?

  assignments DriverVehicleAssignment[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId])
}
//Relacion entre conductores y vehículos para asignaciones temporales
model DriverVehicleAssignment {
  id        String   @id @default(uuid())
  driverId  String
  vehicleId String
  driver    Driver   @relation(fields: [driverId], references: [id])
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])

  startAt   DateTime @default(now())
  endAt     DateTime?

  createdAt DateTime @default(now())

  @@index([driverId])
  @@index([vehicleId])
}
//Enums para los estadsos de los conductores y vehículos
enum DriverStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

model InterestArea {
  id          String   @id @default(uuid())
  companyId   String
  company     TransportCompany @relation(fields: [companyId], references: [id])
  name        String
  description String?
  polygon     Json
  isActive    Boolean  @default(true)
  points      AreaPoint[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([isActive])
}

model AreaPoint {
  id               String   @id @default(uuid())
  areaId           String
  area             InterestArea @relation(fields: [areaId], references: [id], onDelete: Cascade)
  latitude         Float
  longitude        Float
  estimatedAt      DateTime?
  isInsideArea     Boolean
  isVehicleInPoint Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([areaId])
  @@index([estimatedAt])
}
